# Required — LLM API keys
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Database backend: "sqlite" (default, no setup needed) or "supabase"
DB_BACKEND=sqlite

# Optional — only needed if DB_BACKEND=supabase
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Optional — SQLite database path (default: backend/data/ads.db)
# SQLITE_DB_PATH=

# Optional — observability (not yet integrated)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
